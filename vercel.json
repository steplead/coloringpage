{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "ignoreCommand": "echo 'Ignoring build errors for deployment'",
  "env": {
    "SKIP_API_CALLS_DURING_BUILD": "true",
    "NODE_ENV": "production",
    "SKIP_SITEMAP_GENERATION": "true"
  },
  "rewrites": [
    { "source": "/:lang/sitemap.xml", "destination": "/sitemap.xml" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/:lang/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ]
} 