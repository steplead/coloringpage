# Vercel部署配置
# 将此文件重命名为.env.local并填入实际值

# Vercel配置
VERCEL_TOKEN=your_vercel_token_here
VERCEL_PROJECT_ID=your_project_id_here
VERCEL_ORG_ID=your_org_id_here

# Supabase配置
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# AI生成配置
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_URL=your_gemini_api_url_here
GEMINI_MODEL=your_gemini_model_here

# SiliconFlow配置
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_API_URL=your_siliconflow_api_url_here
SILICONFLOW_MODEL=your_siliconflow_model_here

# 图像生成配置
DEFAULT_IMAGE_SIZE=1024
MAX_RETRY_ATTEMPTS=3
MIN_QUALITY_SCORE=7.0

# 缓存配置
CACHE_DURATION=3600
MAX_CACHE_SIZE=100

# SEO配置
NEXT_PUBLIC_SITE_URL=http://localhost:3002
NEXT_PUBLIC_SITE_NAME="AI Coloring Page Generator"
NEXT_PUBLIC_SITE_DESCRIPTION="Create custom coloring pages instantly with AI. Free printable coloring pages for kids and adults."

# 分析跟踪配置（可选）
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_PINTEREST_ID= 